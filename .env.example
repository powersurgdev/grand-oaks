# Database Configuration (Required)
DATABASE_URL=postgresql://localhost/grand_oaks_local

# Blog Admin Password (Required for /admin access)
BLOG_ADMIN_PASSWORD=admin123

# Optional: SendGrid Email Configuration
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# Optional: Pulse Analytics CRM Integration
# PULSE_API_KEY=your_pulse_api_key_here
# PULSE_WEBHOOK_URL=your_pulse_webhook_url_here

# Server Configuration
NODE_ENV=development
PORT=3000
